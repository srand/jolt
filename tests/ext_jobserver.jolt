#!/usr/bin/env python3

import os
import subprocess
import sys
import textwrap
import time

from jolt.utils import timeout
sys.path.append(".")

import jolt

from testsupport import JoltTest
from jolt.plugins.jobserver_main import find_jobserver
from jolt.plugins.jobserver_main import launch_jobserver
from jolt.plugins.jobserver_main import stat_is_fifo


class JobserverExtension(JoltTest):
    name = "ext/jobserver"

    def setup(self, deps, tools):
        super().setup(deps, tools)
        self.tools.setenv("MAKEFLAGS", None)

    def _require_jobserver_support(self):
        if os.name == "nt" or not hasattr(os, "mkfifo"):
            self.skipTest("jobserver FIFO helper is not supported on this platform")

    def _wait_for(self, predicate, timeout=5, interval=0.05, message="condition not met"):
        deadline = time.monotonic() + timeout
        while time.monotonic() < deadline:
            if predicate():
                return
            time.sleep(interval)
        self.fail(message)

    def _pid_exists(self, pid):
        try:
            os.kill(pid, 0)
        except ProcessLookupError:
            return False
        except PermissionError:
            return True
        return True

    def test_launch_and_attach(self):
        self._require_jobserver_support()

        jobserver_path = os.path.join(self.ws, "jobserver-launch")
        jobserver = launch_jobserver(3, path=jobserver_path)

        try:
            self.assertTrue(stat_is_fifo(jobserver.fifo_path))
            self.assertEqual(
                jobserver.get_env()["MAKEFLAGS"],
                "--jobserver-auth=fifo:{}".format(jobserver.fifo_path),
            )

            attached = find_jobserver(path=jobserver_path)
            self.assertIsNotNone(attached)
            self.assertEqual(attached.fifo_path, jobserver.fifo_path)
            self.assertEqual(attached.get_env(), jobserver.get_env())
        finally:
            jobserver.cleanup()

        self.assertFalse(os.path.exists(jobserver.fifo_path))
        self.assertFalse(os.path.exists(jobserver_path))

    def test_launch_config_exports_makeflags(self):
        """
        --- config:

        [jobserver]
        launch = true
        slots = 2
        path = .jobserver

        --- tasks:
        class A(Task):
            def run(self, deps, tools):
                flags = tools.getenv("MAKEFLAGS")
                self.info("MAKEFLAGS={{}}".format(flags))
                tools.write_file("makeflags.txt", flags)
        ---
        """
        self._require_jobserver_support()

        result = self.build("a")

        self.assertBuild(result, "a")
        self.assertContains("makeflags.txt", "--jobserver-auth=fifo:")
        self.assertContains("makeflags.txt", "--jobserver-auth=fifo:.jobserver/jobserver_fifo")
        self._wait_for(
            lambda: not os.path.exists(os.path.join(self.ws, ".jobserver")),
            message="jobserver helper was not cleaned up after Jolt exited",
        )

    def test_helper_stops_when_parent_is_killed(self):
        self._require_jobserver_support()

        jobserver_path = os.path.join(self.ws, "jobserver-parent-death")
        helper_pid_path = os.path.join(self.ws, "jobserver-helper.pid")
        parent_script_path = os.path.join(self.ws, "jobserver_parent.py")
        repo_root = os.path.dirname(os.path.dirname(jolt.__file__))

        with open(parent_script_path, "w") as stream:
            stream.write(textwrap.dedent("""
                import os
                import sys
                import time

                sys.path.insert(0, {!r})

                from jolt.plugins.jobserver_main import launch_jobserver

                jobserver = launch_jobserver(2, path=sys.argv[1], new_session=False)
                with open(sys.argv[2], "w") as pid_file:
                    pid_file.write(str(jobserver.process.pid))
                print("READY", flush=True)
                while True:
                    time.sleep(1)
            """).format(repo_root))

        parent = subprocess.Popen(
            [sys.executable, parent_script_path, jobserver_path, helper_pid_path],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            cwd=self.ws,
        )

        try:
            ready_line = parent.stdout.readline().strip()
            self.assertEqual(ready_line, "READY")

            self._wait_for(
                lambda: os.path.exists(helper_pid_path),
                message="jobserver helper pid file was not written",
            )
            with open(helper_pid_path) as stream:
                helper_pid = int(stream.read().strip())

            fifo_path = os.path.join(jobserver_path, "jobserver_fifo")
            self._wait_for(
                lambda: os.path.exists(fifo_path),
                message="jobserver fifo was not created",
            )

            parent.kill()
            parent.wait(timeout=5)

            self._wait_for(
                lambda: not os.path.exists(fifo_path),
                message="jobserver fifo was not removed after the parent died",
            )
            self._wait_for(
                lambda: not self._pid_exists(helper_pid),
                message="jobserver helper is still running after the parent died",
            )
        finally:
            if parent.stdout is not None:
                parent.stdout.close()
            if parent.poll() is None:
                parent.kill()
                parent.wait(timeout=5)

    def test_slots_limit_parallel_workers(self):
        self._require_jobserver_support()

        slots = 3
        jobserver_path = os.path.join(self.ws, "jobserver-slots")
        jobserver = launch_jobserver(slots, path=jobserver_path)
        worker_script = textwrap.dedent("""
            import os
            import sys
            import time

            fifo_path, acquired_path, release_path, done_path = sys.argv[1:5]
            fd = os.open(fifo_path, os.O_RDWR)
            try:
                token = os.read(fd, 1)
                with open(acquired_path, "w") as stream:
                    stream.write("acquired")
                while not os.path.exists(release_path):
                    time.sleep(0.01)
                os.write(fd, token)
            finally:
                os.close(fd)

            with open(done_path, "w") as stream:
                stream.write("done")
        """)
        workers = []

        try:
            for index in range(slots):
                acquired_path = os.path.join(self.ws, "worker-{}.acquired".format(index))
                release_path = os.path.join(self.ws, "worker-{}.release".format(index))
                done_path = os.path.join(self.ws, "worker-{}.done".format(index))
                process = subprocess.Popen(
                    [
                        sys.executable,
                        "-c",
                        worker_script,
                        jobserver.fifo_path,
                        acquired_path,
                        release_path,
                        done_path,
                    ],
                    stdin=subprocess.DEVNULL,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    cwd=self.ws,
                )
                workers.append((process, acquired_path, release_path, done_path))

            self._wait_for(
                lambda: sum(os.path.exists(acquired_path) for _, acquired_path, _, _ in workers) == slots - 1,
                message="expected only slots - 1 workers to acquire jobserver tokens immediately",
            )

            time.sleep(0.2)
            self.assertEqual(
                sum(os.path.exists(acquired_path) for _, acquired_path, _, _ in workers),
                slots - 1,
            )

            for _, acquired_path, release_path, _ in workers:
                if os.path.exists(acquired_path):
                    with open(release_path, "w"):
                        pass

            self._wait_for(
                lambda: sum(os.path.exists(acquired_path) for _, acquired_path, _, _ in workers) == slots,
                message="blocked worker never acquired a token after one was released",
            )

            for _, acquired_path, release_path, _ in workers:
                if os.path.exists(acquired_path) and not os.path.exists(release_path):
                    with open(release_path, "w"):
                        pass

            self._wait_for(
                lambda: all(os.path.exists(done_path) for _, _, _, done_path in workers),
                message="not all workers released their tokens and exited",
            )
        finally:
            for process, acquired_path, release_path, _ in workers:
                if os.path.exists(acquired_path) and not os.path.exists(release_path):
                    with open(release_path, "w"):
                        pass
                if process.poll() is None:
                    process.terminate()
                    try:
                        process.wait(timeout=5)
                    except subprocess.TimeoutExpired:
                        process.kill()
                        process.wait(timeout=5)
            jobserver.cleanup()
